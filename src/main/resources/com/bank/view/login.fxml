<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<!--
    login.fxml — Login screen for Banka Faiz Hesaplama Sistemi.
    Controller: com.bank.controller.LoginController
    Design: Dark theme with accent red (#e94560), inline styles for self-contained demo.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bank.controller.LoginController"
      alignment="CENTER"
      spacing="24"
      minWidth="420"
      minHeight="380"
      style="-fx-background-color: #1a1a2e; -fx-padding: 50 60;">

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <VBox alignment="CENTER" spacing="6">
        <Text text="🏦"
              style="-fx-font-size: 40px;"/>
        <Text text="Banka Faiz Hesaplama"
              style="-fx-font-size: 22px; -fx-fill: #e94560; -fx-font-weight: bold;"/>
        <Text text="Sisteme Giriş Yapınız"
              style="-fx-font-size: 13px; -fx-fill: #8888aa;"/>
    </VBox>

    <!-- ── Divider line ─────────────────────────────────────────────────────── -->
    <HBox style="-fx-background-color: #e94560; -fx-pref-height: 2;" maxWidth="300"/>

    <!-- ── Form ────────────────────────────────────────────────────────────── -->
    <GridPane hgap="12" vgap="16" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints minWidth="230"/>
        </columnConstraints>

        <!-- Username -->
        <Label text="Kullanıcı Adı:"
               GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-text-fill: #ccccdd; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <TextField fx:id="txtKullaniciAdi"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"
                   promptText="Kullanıcı adınızı girin"
                   style="-fx-background-color: #16213e;
                          -fx-text-fill: #ffffff;
                          -fx-prompt-text-fill: #555577;
                          -fx-border-color: #e94560;
                          -fx-border-radius: 6;
                          -fx-background-radius: 6;
                          -fx-padding: 9 12;
                          -fx-font-size: 13px;"/>

        <!-- Password -->
        <Label text="Şifre:"
               GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-text-fill: #ccccdd; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <PasswordField fx:id="txtSifre"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"
                       promptText="Şifrenizi girin"
                       style="-fx-background-color: #16213e;
                              -fx-text-fill: #ffffff;
                              -fx-prompt-text-fill: #555577;
                              -fx-border-color: #e94560;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 9 12;
                              -fx-font-size: 13px;"/>
    </GridPane>

    <!-- ── Login Button ────────────────────────────────────────────────────── -->
    <Button fx:id="btnGiris"
            text="🔑  GİRİŞ YAP"
            onAction="#handleLogin"
            defaultButton="true"
            maxWidth="260"
            style="-fx-background-color: #e94560;
                   -fx-text-fill: #ffffff;
                   -fx-font-size: 14px;
                   -fx-font-weight: bold;
                   -fx-padding: 11 0;
                   -fx-background-radius: 8;
                   -fx-cursor: hand;">
        <VBox.margin>
            <Insets top="6"/>
        </VBox.margin>
    </Button>

    <!-- ── Hint ────────────────────────────────────────────────────────────── -->
    <Text text="Varsayılan giriş bilgileri:  admin  /  1234"
          style="-fx-font-size: 11px; -fx-fill: #44445a;"/>

</VBox>
