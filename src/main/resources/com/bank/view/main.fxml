<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<!--
    main.fxml — Main interest calculation screen.
    Controller: com.bank.controller.MainController
    Design: Dark theme matching login.fxml; accent colors #e94560 (red) and #0f3460 (navy).
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bank.controller.MainController"
            minWidth="600"
            minHeight="520"
            style="-fx-background-color: #1a1a2e;">

    <!-- ════════════════════════════════════════════════════════════
         TOP — Title bar with app name and logout button
         ════════════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="0"
              style="-fx-background-color: #16213e;
                     -fx-padding: 14 22;
                     -fx-border-color: transparent transparent #e94560 transparent;
                     -fx-border-width: 0 0 2 0;">

            <!-- App title -->
            <Text text="🏦  Banka Faiz Hesaplama Sistemi"
                  style="-fx-font-size: 17px; -fx-fill: #e94560; -fx-font-weight: bold;"/>

            <!-- Spacer pushes the logout button to the right -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Logout button -->
            <Button fx:id="btnCikis"
                    text="🚪  Çıkış Yap"
                    onAction="#handleCikis"
                    style="-fx-background-color: #e94560;
                           -fx-text-fill: white;
                           -fx-font-size: 12px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;
                           -fx-padding: 8 16;"/>
        </HBox>
    </top>

    <!-- ════════════════════════════════════════════════════════════
         CENTER — Input form and result panel
         ════════════════════════════════════════════════════════════ -->
    <center>
        <VBox alignment="CENTER"
              spacing="22"
              style="-fx-padding: 30 50;">

            <!-- ── Section label ──────────────────────────────────────────── -->
            <Label text="Hesap Bilgileri"
                   style="-fx-text-fill: #8888aa;
                          -fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-padding: 0 0 0 4;"/>

            <!-- ── Input grid ─────────────────────────────────────────────── -->
            <GridPane hgap="16" vgap="14" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints minWidth="140" halignment="RIGHT"/>
                    <ColumnConstraints minWidth="280"/>
                </columnConstraints>

                <!-- Müşteri Adı -->
                <Label text="Müşteri Adı:"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ccccdd; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtMusteriAdi"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                           promptText="Örn: Ahmet Yılmaz"
                           style="-fx-background-color: #16213e;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #555577;
                                  -fx-border-color: #0f3460;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 9 12;
                                  -fx-font-size: 13px;"/>

                <!-- Ana Para -->
                <Label text="Ana Para (TL):"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ccccdd; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtAnaPara"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                           promptText="Örn: 50000"
                           style="-fx-background-color: #16213e;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #555577;
                                  -fx-border-color: #0f3460;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 9 12;
                                  -fx-font-size: 13px;"/>

                <!-- Vade Ay -->
                <Label text="Vade (Ay):"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ccccdd; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtVadeAy"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                           promptText="Örn: 12"
                           style="-fx-background-color: #16213e;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #555577;
                                  -fx-border-color: #0f3460;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 9 12;
                                  -fx-font-size: 13px;"/>

                <!-- Faiz Oranı -->
                <Label text="Faiz Oranı (%):"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ccccdd; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="txtFaizOrani"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                           promptText="Örn: 30.5"
                           style="-fx-background-color: #16213e;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #555577;
                                  -fx-border-color: #0f3460;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 9 12;
                                  -fx-font-size: 13px;"/>

                <!-- Hesap Türü -->
                <Label text="Hesap Türü:"
                       GridPane.rowIndex="4" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ccccdd; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cmbHesapTuru"
                          GridPane.rowIndex="4" GridPane.columnIndex="1"
                          maxWidth="1.7976931348623157E308"
                          style="-fx-background-color: #16213e;
                                 -fx-border-color: #0f3460;
                                 -fx-border-radius: 6;
                                 -fx-background-radius: 6;
                                 -fx-font-size: 13px;"/>
            </GridPane>

            <!-- ── Action buttons ─────────────────────────────────────────── -->
            <HBox alignment="CENTER" spacing="16">
                <Button fx:id="btnHesapla"
                        text="📊  Hesapla"
                        onAction="#handleHesapla"
                        defaultButton="true"
                        style="-fx-background-color: #e94560;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-pref-width: 160;
                               -fx-padding: 11 0;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;"/>
                <Button fx:id="btnTemizle"
                        text="🔄  Temizle"
                        onAction="#handleTemizle"
                        style="-fx-background-color: #0f3460;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-pref-width: 160;
                               -fx-padding: 11 0;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;"/>
            </HBox>

            <Separator style="-fx-background-color: #2a2a4a;"/>

            <!-- ── Result panel ────────────────────────────────────────────── -->
            <VBox alignment="CENTER"
                  spacing="10"
                  minWidth="480"
                  minHeight="160"
                  style="-fx-background-color: #16213e;
                         -fx-border-color: #e94560;
                         -fx-border-width: 2;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-padding: 18 24;">

                <Label text="HESAPLAMA SONUCU"
                       style="-fx-text-fill: #e94560;
                              -fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-letter-spacing: 1.5;"/>

                <Label fx:id="lblSonuc"
                       text="Hesaplamak için formu doldurunuz."
                       wrapText="true"
                       textAlignment="CENTER"
                       maxWidth="480"
                       style="-fx-text-fill: #a8f0c6;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-line-spacing: 4;"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>
